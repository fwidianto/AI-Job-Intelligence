# =============================================================================
# Job Intelligence Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# =============================================================================
# GOOGLE SHEETS CONFIGURATION
# =============================================================================

# Google Sheets Spreadsheet ID
# Get from URL: https://docs.google.com/spreadsheets/d/[THIS_ID]/edit
GOOGLE_SHEETS_ID=

# Path to Service Account credentials JSON file
# Download from Google Cloud Console > IAM > Service Accounts > Keys
GOOGLE_CREDENTIALS=credentials/service-account.json

# =============================================================================
# EMAIL NOTIFICATIONS (Gmail SMTP)
# =============================================================================

# Gmail address for sending notifications
EMAIL_SMTP_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Create at: Google Account > Security > App Passwords
EMAIL_SMTP_PASSWORD=your-app-password

# Email addresses to receive job alerts (comma-separated)
EMAIL_TO_ADDRS=your-email@gmail.com

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Config directory path (default: config)
CONFIG_DIR=config

# Run mode: development, production
RUN_MODE=development